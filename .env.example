# 邮箱配置（支持任意 IMAP 邮箱）
IMAP_SERVER=imap.qq.com
IMAP_PORT=993
IMAP_USER=your_email@example.com
IMAP_PASSWORD=your_password_or_auth_code

# SMTP 配置（用于发送邮件推送，通常与 IMAP 同服务器，无需单独配置）
# SMTP_SERVER=smtp.qq.com
# SMTP_PORT=465

# 邮件推送收件人（多个用逗号分隔）
EMAIL_RECIPIENTS=334223834@qq.com

# AI API 配置（支持 OpenAI 兼容接口）
AI_API_KEY=your_api_key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# 微信公众号配置（可选，用于自动发布草稿）
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# 图片生成配置（可选，用于生成封面图）
# 如果不配置，将使用 AI_API_KEY 和 AI_BASE_URL
IMAGE_API_KEY=your_image_api_key
IMAGE_BASE_URL=https://api.openai.com/v1
IMAGE_MODEL=dall-e-3

# ===== 向后兼容（旧变量名，已废弃，建议迁移到上述新变量） =====
# QQ_EMAIL=your_email@qq.com
# QQ_EMAIL_AUTH_CODE=your_authorization_code
# ANTHROPIC_API_KEY=your_api_key
# ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
# ANTHROPIC_MODEL=qwen3.5-plus